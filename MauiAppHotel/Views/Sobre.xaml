<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
             x:Class="MauiAppHotel.Sobre"
             Title="Sobre"
             NavigationPage.HasNavigationBar="False"
             BackgroundImageSource="background_2.jpg">
    
    <VerticalStackLayout
        Padding="20"
        Spacing="15"
        VerticalOptions="Center" 
        HorizontalOptions="Center">

        <Label 
            Text="Desenvolvido por Lydia. 2026."
            TextColor="WhiteSmoke"
            FontFamily="SilkscreenRegular"
            HorizontalTextAlignment="Center"
            HorizontalOptions="Center"/>

        <Button
            Text="Voltar"
            TextColor="AntiqueWhite"
            Clicked="Voltar_Clicked"
            BackgroundColor="#0B0F1A"
            FontFamily="SilkscreenRegular"
            FontAttributes="Bold"
            FontSize="14"
            CornerRadius="25"
            HeightRequest="55"
            WidthRequest="200"/>

    </VerticalStackLayout>

</ContentPage>
